config vpn ipsec phase1-interface
    edit "VPN-Cliente"
        set interface "port1"
        set peertype any
        set net-device disable
        set proposal aes128-sha1
        set dhgrp 2
        set remote-gw 172.20.11.1
        set psksecret Matricula20241165
    next
end

config vpn ipsec phase2-interface
    edit "VPN-Cliente"
        set phase1name "VPN-Cliente"
        set proposal aes128-sha1
        set dhgrp 2
        set src-subnet 10.20.11.0 255.255.255.0
        set dst-subnet 10.24.65.0 255.255.255.0
    next
end

config router static
    edit 2
        set dst 10.24.65.0 255.255.255.0
        set device "VPN-Cliente"
    next
end

config firewall policy
    edit 1
        set name "LAN_to_VPN"
        set srcintf "port2"
        set dstintf "VPN-Cliente"
        set srcaddr "all"
        set dstaddr "all"
        set action accept
        set schedule "always"
        set service "ALL"
    next
    edit 2
        set name "VPN_to_LAN"
        set srcintf "VPN-Cliente"
        set dstintf "port2"
        set srcaddr "all"
        set dstaddr "all"
        set action accept
        set schedule "always"
        set service "ALL"
    next
end
